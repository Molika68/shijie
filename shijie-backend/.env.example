PORT=3000

# 本地开发用 pglite（零配置）；上线时改为 Neon 连接串
DATABASE_URL=pglite://local

JWT_SECRET=change-me-to-a-random-secret
APP_PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:10086

# AI 提供商：dashscope（原文档默认）| mock | gemini（备选）
AI_PROVIDER=dashscope

# 阿里云 DashScope API Key（必填后重启后端）
# 申请：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# 模型可选项（默认已按百炼最新文档配置）
DASHSCOPE_VISION_MODEL=qwen-vl-plus
DASHSCOPE_IMAGE_MODEL=wan2.7-image-pro
DASHSCOPE_IMAGE_SIZE=1K
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry

# 备选：Google Gemini（零成本方案可选，非原文档方案）
GEMINI_API_KEY=

AI_DAILY_LIMIT=100
UPLOAD_DIR=./uploads

RESEND_API_KEY=
EMAIL_FROM=识界 <onboarding@resend.dev>

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shijie
R2_PUBLIC_URL=
